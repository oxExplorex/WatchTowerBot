# Telegram / Gemini
TOKEN_BOT=
GEMINI_KEY=
# Debug lifecycle logs for AI requests (true/false)
GEMINI_ACTION_DEBUG=false

# Admin IDs (comma-separated)
# Example: ADMIN_ID_LIST=123456789,987654321
ADMIN_ID_LIST=

# Logging
LOG_PATH=data/logs/log_{d}.log

# DB selection
# PostgreSQL: postgresql+asyncpg
# SQLite: sqlite+aiosqlite
DB_ENGINE=postgresql+asyncpg

# PostgreSQL settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gemini_message_manager
DB_ADMIN_NAME=postgres

# Optional sqlite path (used if DB_ENGINE=sqlite+aiosqlite)
DB_PATH=data/gemini_message_manager.sqlite3

# Optional explicit update source
# BOT_UPDATE_REPO_OWNER=oxExplorex
# BOT_UPDATE_REPO_NAME=gemini_message_manager_tg
# BOT_UPDATE_REPO_BRANCH=main
